# Copy this file to secrets.toml and fill in your Yahoo API credentials
# DO NOT commit secrets.toml to git!

# Yahoo Fantasy Sports API Credentials
YAHOO_CONSUMER_KEY = "your_consumer_key_here"
YAHOO_CONSUMER_SECRET = "your_consumer_secret_here"
YAHOO_ACCESS_TOKEN_JSON = "your_access_token_json_here"
GAME_CODE = "mlb"

# Optional (if needed)
# YAHOO_REFRESH_TOKEN = "your_refresh_token_here"
